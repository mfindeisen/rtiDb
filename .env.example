# Production Environment Configuration for rtiDb
# Copy this file to `.env` on your server and modify the values.
# Optional for local Docker: without `.env`, docker-compose defaults to admin / admin.

# Administrator Username for the dashboard
ADMIN_USERNAME=admin

# Administrator Password (CHANGE THIS TO A SECURE PASSWORD)
ADMIN_PASSWORD=admin

# JWT Secret Key for token signing (CHANGE THIS to a random long string)
JWT_SECRET=change_this_to_a_random_long_string